digraph JiTArchitectureComparisonSimple {
  graph [
    rankdir=LR,
    bgcolor="white",
    pad="0.35",
    nodesep="0.45",
    ranksep="0.75",
    splines=ortho,
    fontname="Helvetica",
    fontsize=22,
    label="JiT Architecture Change: Shared Trunk to Dual Stream",
    labelloc="t",
    labeljust="c"
  ];

  node [
    shape=box,
    style="rounded,filled",
    fontname="Helvetica",
    fontsize=14,
    margin="0.18,0.12",
    color="#4A4A4A",
    penwidth=1.4
  ];

  edge [
    color="#5C6670",
    penwidth=1.6,
    arrowsize=0.8
  ];

  subgraph cluster_before {
    label="Before: JiT-B/2-4C";
    color="#D7B55A";
    fillcolor="#FFF5D9";
    style="rounded,filled";
    penwidth=1.6;

    b0 [label="Latent + DINO inputs", fillcolor="#FFFDF6"];
    b1 [label="Concat into one\nshared token sequence", fillcolor="#FFFDF6"];
    b2 [label="One shared\ntransformer trunk", fillcolor="#FFFDF6"];
    b3 [label="Shared context\ninserted at block 4", fillcolor="#FFFDF6"];
    b4 [label="Split back into\nlatent and DINO heads", fillcolor="#FFFDF6"];

    b0 -> b1 -> b2 -> b3 -> b4;
  }

  subgraph cluster_after {
    label="After: JiT-Dual-B/2-4C-896";
    color="#78AEE0";
    fillcolor="#EAF5FF";
    style="rounded,filled";
    penwidth=1.6;

    ctx [label="Per-stream context\nfrom block 0", fillcolor="#F2FBF5", color="#5D8A68"];

    l0 [label="Latent input", fillcolor="#F9FCFF"];
    d0 [label="DINO input", fillcolor="#F9FCFF"];
    { rank=same; l0; d0; }

    l1 [label="Latent tower\n(separate weights)", fillcolor="#F9FCFF"];
    d1 [label="DINO tower\n(separate weights)", fillcolor="#F9FCFF"];
    { rank=same; l1; d1; }

    fusion [label="Bidirectional cross-fusion\nonly at blocks 4 and 8", fillcolor="#F2FBF5", color="#5D8A68"];

    l2 [label="Latent head", fillcolor="#F9FCFF"];
    d2 [label="DINO head", fillcolor="#F9FCFF"];
    { rank=same; l2; d2; }

    l0 -> l1;
    d0 -> d1;
    ctx -> l1;
    ctx -> d1;
    l1 -> fusion;
    d1 -> fusion;
    fusion -> l2;
    fusion -> d2;
  }

  note [
    shape=box,
    style="rounded,filled",
    fillcolor="#F2FBF5",
    color="#5D8A68",
    penwidth=1.4,
    fontsize=15,
    label="Main idea:\nold JiT mixes both modalities inside one trunk;\nnew JiT keeps them separate and lets them exchange information only at selected fusion points."
  ];

  b4 -> ctx [style=invis, weight=20];
  b4 -> note [style=invis, weight=5];
  d2 -> note [style=invis, weight=5];
}
